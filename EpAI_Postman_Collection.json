{
  "info": {
    "name": "EpAI - START HACK 2026",
    "description": "Colección completa de Endpoints del Backend EpAI. Módulos: Admin, Analista, Clínico y Paciente.\nURL base local: http://127.0.0.1:8001\nURL Cloud Run: https://epai-service-629631305612.us-central1.run.app",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Administración General (Clinics)",
      "item": [
        {
          "name": "0.1 Create Clinic",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hospital Central\",\n  \"country\": \"Switzerland\",\n  \"system_type\": \"EPIC\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/clinics/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clinics", ""]
            }
          }
        },
        {
          "name": "0.2 List Clinics",
          "request": {
            "method": "GET",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/clinics/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clinics", ""]
            }
          }
        }
      ]
    },
    {
      "name": "1. Módulo Analista (Data Engineer)",
      "item": [
        {
          "name": "1.1 Upload File (Mapping)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/mapping/upload/1?use_ai=true",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "mapping", "upload", "1"],
              "query": [
                { "key": "use_ai", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "1.2 Edit Column (Correction)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/mapping/job/JOB_ID/column?source=old_name&new_target=coLastname",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "mapping", "job", "JOB_ID", "column"],
              "query": [
                { "key": "source", "value": "old_name" },
                { "key": "new_target", "value": "coLastname" }
              ]
            }
          }
        },
        {
          "name": "1.3 Approve Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"decisions\": [{\"source\": \"unknown_col\", \"accepted_target\": \"coFirstname\"}]}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/mapping/approve/JOB_ID",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "mapping", "approve", "JOB_ID"]
            }
          }
        },

        {
          "name": "1.4 Staging Summary (Legacy)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/staging/summary",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "staging", "summary"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Módulo Dashboard & Analítica Avanzada",
      "item": [
        {
          "name": "2.1 Executive Stats (Cards & Distribution)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/dashboard/executive-stats",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dashboard", "executive-stats"]
            }
          },
          "description": "Devuelve Total Records, Quality Score, Mapeo y Distribución por Formato de archivo."
        },
        {
          "name": "2.2 Ingestion History (Selector)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/dashboard/ingestion/history",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dashboard", "ingestion", "history"]
            }
          },
          "description": "Lista todos los archivos procesados para que el usuario elija cuál auditar."
        },
        {
          "name": "2.3 Get Ingestion Audit (Before vs After)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/dashboard/ingestion/JOB_ID/audit",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dashboard", "ingestion", "JOB_ID", "audit"]
            }
          }
        },
        {
          "name": "2.4 Get Rejected Rows (Data Integrity)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/dashboard/ingestion/JOB_ID/rejected",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dashboard", "ingestion", "JOB_ID", "rejected"]
            }
          },
          "description": "Muestra filas rechazadas por duplicación (dentro del archivo o en DB) o falta de IDs obligatorios."
        },

        {
          "name": "2.5 Column Metadata & Tooltips",
          "request": {
            "method": "GET",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/dashboard/columns/tbImportLabsData/metadata",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dashboard", "columns", "tbImportLabsData", "metadata"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Módulo Clínico (Telemetría & Enfermería)",

      "item": [
        {
          "name": "3.1 Upload Nursing Reports (CSV)",

          "request": {
            "method": "POST",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/clinical/nursing/upload/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clinical", "nursing", "upload", "1"]
            }
          },
          "description": "Sube un CSV de reportes de enfermería. Extrae síntomas, intervenciones y evaluación con NLP (Phi-3). Respuesta incluye _valid y _validation_errors para edición."
        },
        {
          "name": "3.2 Upload Nursing Reports (PDF Multi-Page)",

          "request": {
            "method": "POST",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/clinical/nursing/upload/4",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clinical", "nursing", "upload", "4"]
            }
          },
          "description": "Sube un PDF de reportes de enfermería. Extrae 1 reporte por página con Regex + OCR fallback (LLaVA). Devuelve datos editables con PatientID, CaseID, Ward, etc."
        },
        {
          "name": "3.3 Get Telemetry Alerts",

          "request": {
            "method": "GET",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/telemetry/alerts?patient_id=PAT123",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "telemetry", "alerts"],
              "query": [
                { "key": "patient_id", "value": "PAT123", "description": "Opcional: filtrar por paciente" }
              ]
            }
          }
        },
        {
          "name": "3.4 Ingest Sensor Data - CAÍDA (Score 100/100)",

          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coPatientId\": \"PAT123\",\n  \"coDevice_id\": \"MAT-1434\",\n  \"coTimestamp\": \"2026-03-18 10:00:00\",\n  \"coBed_occupied_0_1\": 0,\n  \"coMovement_score_0_100\": 100,\n  \"coAccel_magnitude_g\": 4.5,\n  \"coPressure_zone1_0_100\": 0\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/telemetry/ingest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "telemetry", "ingest"]
            }
          },
          "description": "Simula caída: accel>2g (+40), movement>80 (+30), pressure<10 (+20), bed_empty (+10) = Score 100. Genera alerta Critical."
        },
        {
          "name": "3.5 Ingest Sensor Data - NORMAL (Sin Alerta)",

          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coPatientId\": \"PAT123\",\n  \"coDevice_id\": \"MAT-1434\",\n  \"coTimestamp\": \"2026-03-18 10:00:01\",\n  \"coBed_occupied_0_1\": 1,\n  \"coMovement_score_0_100\": 15,\n  \"coAccel_magnitude_g\": 1.0,\n  \"coPressure_zone1_0_100\": 55\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/telemetry/ingest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "telemetry", "ingest"]
            }
          },
          "description": "Datos normales: accel=1g, movement=15, pressure=55, bed_occupied=1. Score=0, sin alerta."
        },
        {
          "name": "3.6 List Registered Devices (Beds)",

          "request": {
            "method": "GET",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/telemetry/devices?clinic_id=1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "telemetry", "devices"],
              "query": [
                { "key": "clinic_id", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "3.7 Map Device to Bed/Location",

          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"MAT-9999\",\n  \"clinic_id\": 1,\n  \"location\": \"ICU - Bed 12\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/telemetry/devices/map",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "telemetry", "devices", "map"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Módulo Paciente (Assistant, Vision & TTS)",

      "item": [
        {
          "name": "4.0 Register Patient Profile",

          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clinic_id\": 1,\n  \"patient_id\": \"PAT_0054\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"gender\": \"M\",\n  \"dob\": \"1980-05-15\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient-assistant/profile/create",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient-assistant", "profile", "create"]
            }
          }
        },
        {
          "name": "4.1 Interpret Labs",

          "request": {
            "method": "GET",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/patient-assistant/interpret-labs/1/12342",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient-assistant", "interpret-labs", "1", "12342"]
            }
          }
        },
        {
          "name": "4.2 Interpret Document (Imagen)",

          "request": {
            "method": "POST",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "", "description": "Imagen JPG/PNG o PDF" },
                { "key": "prompt", "value": "¿Qué indican estos resultados?", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient-assistant/interpret-image",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient-assistant", "interpret-image"]
            }
          },
          "description": "Acepta imágenes Y PDFs. Extrae texto (PyMuPDF/LLaVA OCR) y luego Phi-3 lo interpreta según el prompt del paciente. Respuesta incluye extracted_text y explanation."
        },
        {
          "name": "4.3 Interpret Document (PDF)",

          "request": {
            "method": "POST",
            "header": [
              { "key": "accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "", "description": "PDF médico" },
                { "key": "prompt", "value": "Resume los reportes de enfermería", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient-assistant/interpret-image",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient-assistant", "interpret-image"]
            }
          },
          "description": "Mismo endpoint que 3.2 pero demostrando PDF. PyMuPDF extrae texto digital; si es escaneado usa LLaVA OCR."
        },
        {
          "name": "4.4 Chat - Primera Pregunta (Sin conversation_id)",

          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clinic_id\": 1,\n  \"query\": \"¿Qué es la presión arterial alta?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient-assistant/chat",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient-assistant", "chat"]
            }
          },
          "description": "Sin patient_id ni conversation_id. El LLM responde directamente y genera un conversation_id nuevo para seguir el hilo."
        },
        {
          "name": "4.5 Chat - Seguir Conversación (Con conversation_id)",

          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clinic_id\": 1,\n  \"query\": \"¿Y qué alimentos debo evitar?\",\n  \"conversation_id\": \"PEGAR_EL_UUID_AQUI\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient-assistant/chat",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient-assistant", "chat"]
            }
          },
          "description": "Envía el conversation_id de la respuesta anterior. El LLM recuerda el contexto de la conversación."
        },
        {
          "name": "4.6 Chat - Con Patient ID (Personalizado)",

          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clinic_id\": 1,\n  \"patient_id\": \"PAT_0054\",\n  \"query\": \"¿Debo preocuparme por mi colesterol si tomé atorvastatina hoy?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient-assistant/chat",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient-assistant", "chat"]
            }
          },
          "description": "Con patient_id: Si existe en la base, el LLM enriquece la respuesta con el historial médico real del paciente."
        },
        {
          "name": "4.7 Speak (Kokoro TTS)",

          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hola, tus resultados son completamente normales.\",\n  \"language\": \"es\",\n  \"speed\": 1.0\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/patient-assistant/speak",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patient-assistant", "speak"]
            }
          },
          "description": "Genera audio WAV offline. Soporta: es (español), en (inglés), de (alemán). Respuesta: binary audio/wav."
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8001"
    }
  ]
}
